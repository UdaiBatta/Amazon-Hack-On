# Copy to .env to enable live AI. Default is offline-safe "mock" mode.

# Provider for vision / perception:
#   mock      → cached/stub, fully offline, $0 (use this for the stage demo)
#   gemini    → Google Gemini Flash free tier ($0, recommended for live AI)
#   aws       → Gemini vision + Amazon Rekognition (serial OCR + labels)
#               + Bedrock Claude Haiku (disposition prose). Needs AWS creds.
#   anthropic → Claude direct (paid)
#   bedrock   → Claude Sonnet vision on Bedrock (paid)
RELAY_AI_MODE=gemini

# Free key from https://aistudio.google.com/apikey (no billing required)
RELAY_GEMINI_API_KEY=
# NOTE: gemini-2.0-flash has 0 free-tier quota on new projects (429).
# Use flash-lite, which has its own free daily bucket.
RELAY_GEMINI_MODEL=gemini-2.5-flash-lite

# Optional paid / AWS providers
# RELAY_ANTHROPIC_API_KEY=sk-ant-...
# RELAY_AWS_REGION=us-east-1   (aws/bedrock modes use the default boto3 cred chain)

RELAY_AI_TIMEOUT_S=8.0

# Local zero-cost fingerprint embeddings (needs catalog images in seed/catalog_images/)
RELAY_USE_LOCAL_EMBEDDINGS=true
